#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  karaoke-process-v2 INPUT_FILE [options]

Description:
  v2 of karaoke-process: same luminance-LUT pipeline plus optional
  intro/outro pass-through or blackout. The first or last N seconds of
  the video can either be preserved unaltered (no mask, no LUT) or
  replaced with a fully black frame, then concatenated with the
  processed body in a single ffmpeg pass. Audio is stream-copied from
  the original, untouched.

  Pipeline (per frame in the body window):
    1. Mask part of the frame with black
    2. Convert remaining image to grayscale
    3. Remap luminance bands to fixed colors:
         - black  = 0,0,0
         - white  = 255,255,255
         - green  = 0,200,0

Required arguments:
  INPUT_FILE   Path to the input video file

Optional arguments:
  -t TOP%      Top margin to mask, as percent of height
               Default: 5%
  -b BOTTOM%   Bottom margin to mask, as percent of height
               Default: 15%
  -l LEFT%     Left margin to mask, as percent of width
               Default: 15%
  -r RIGHT%    Right margin to mask, as percent of width
               Default: 5%
  -lo LOW      Lower threshold (0-255)
               Default: 40
  -hi HIGH     Upper threshold (0-255)
               Default: 80
  --intro-preserve SECONDS
               Preserve the first N seconds of the video unaltered (no
               mask, no LUT), then concatenate the processed body.
               Must be > 0 and < video duration. Mutually exclusive
               with --intro-blackout. Ignored in still-frame mode (-f).
  --intro-blackout SECONDS
               Replace the first N seconds of the video with a fully
               black frame (audio preserved), then concatenate the
               processed body. Same time constraints as --intro-preserve.
               Mutually exclusive with --intro-preserve. Ignored in
               still-frame mode (-f).
  --outro-preserve SECONDS
               Preserve the last N seconds of the video unaltered (no
               mask, no LUT), concatenated after the processed body.
               Must be > 0 and < video duration. Mutually exclusive
               with --outro-blackout. Ignored in still-frame mode (-f).
  --outro-blackout SECONDS
               Replace the last N seconds of the video with a fully
               black frame (audio preserved), concatenated after the
               processed body. Same time constraints as --outro-preserve.
               Mutually exclusive with --outro-preserve. Ignored in
               still-frame mode (-f).
  -z PERCENT   Apply a uniform zoom (centered) of PERCENT% to the
               processed frames, before the LUT. Output dimensions are
               unchanged (scale up, then center-crop back). Intro and
               outro frames are NOT zoomed. Must be > 0 and <= 100.
  -f SECONDS   Extract and process only a still frame at this timestamp
  --corners-only
               Black out only the corners implied by the margins instead
               of blacking out full top/bottom/left/right strips
  --invert-bands
               Swap the mid and high output colors. Use this when the
               sung text is at LOWER luminance than the unsung text
               (e.g., orange sung on bright white unsung).
                 Default       : black / white / green   (low / mid / high)
                 --invert-bands: black / green / white   (low / mid / high)
  --outline N  Add a two-ring gray halo around the LUT'd text. Inner stamps
               at offsets +/-N (gray 80), outer stamps at offsets +/-2N
               (gray 220), in 8 compass directions, alpha-composited so
               the colored text core stays clean. Set N=0 to disable.
               Default: 2. Maximum: 20.
  --sung-color HEX
               Color of the sung lyrics (the band that the original tool
               renders as green). 6-digit hex, optional leading #.
               Default: 00C800. Examples: --sung-color FFA500 (orange),
               --sung-color "#FF1493" (deep pink).
  --bg-color HEX
               Activate background darken. Pixels matching this color
               (in RGB distance, via ffmpeg's colorkey filter) are darkened
               toward black before the LUT. Inserted AFTER masking and
               BEFORE zoom/grayscale/LUT/outline. Intro/outro branches
               are unaffected. 6-digit hex, optional leading #. When this
               flag is absent, background darken is OFF.
  --bg-strength N
               Darken strength 0-100 (default 85). 100 = matched pixels
               become pure black; 0 = no darkening. Only used with --bg-color.
  --bg-range N Color range 0-100 (default 35). How wide a band of similar
               hues counts as background. Wider = more darkened, but risks
               eating text edges. Only used with --bg-color.
  --bg-blend N Edge softness 0-100 (default 10). Feathering of the
               match/no-match transition. Only used with --bg-color.
  --no-lut     Skip the grayscale + 3-band LUT step. Output preserves the
               original (multi-color) lyrics on a black background — useful
               for channels like Party Tyme that use different font colors
               for different singers in duets, where the LUT would quantize
               them to a single sung color. Mask, --bg-color, -z, and
               --outline still apply. -lo, -hi, --invert-bands, and
               --sung-color are silently ignored when this flag is set.
  -o DIR       Write outputs (preview PNGs and processed video) to DIR
               instead of the input file's directory. DIR is created if
               needed.
  -h           Show this help

Examples:
  karaoke-process-v2 "/path/video.mp4"
  karaoke-process-v2 "/path/video.mp4" --intro-preserve 5
  karaoke-process-v2 "/path/video.mp4" --intro-preserve 5 -z 10 -lo 40 -hi 100
  karaoke-process-v2 "/path/video.mp4" --intro-blackout 3 --outro-blackout 4
  karaoke-process-v2 "/path/video.mp4" --intro-preserve 5 --outro-preserve 8
  karaoke-process-v2 "/path/video.mp4" -lo 40 -hi 200 --invert-bands
  karaoke-process-v2 "/path/video.mp4" --outline 3
  karaoke-process-v2 "/path/video.mp4" --outline 0
  karaoke-process-v2 "/path/video.mp4" --no-lut --outline 2
  karaoke-process-v2 "/path/video.mp4" --no-lut --bg-color 130FE6 --bg-strength 95
  karaoke-process-v2 "/path/video.mp4" -t 20% -b 20% -l 20% -r 20% -lo 24 -hi 80
  karaoke-process-v2 "/path/video.mp4" -f 90
  karaoke-process-v2 "/path/video.mp4" -b 20% -l 20% --corners-only -f 90
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

parse_percent() {
  local raw="$1"
  [[ "$raw" =~ ^([0-9]+([.][0-9]+)?)%$ ]] || die "Invalid percentage: $raw"
  printf '%s\n' "${BASH_REMATCH[1]}"
}

validate_threshold() {
  local name="$1"
  local value="$2"
  [[ "$value" =~ ^[0-9]+$ ]] || die "$name must be an integer: $value"
  (( value >= 0 && value <= 255 )) || die "$name must be between 0 and 255: $value"
}

percent_to_px() {
  local percent="$1"
  local dim="$2"
  awk -v p="$percent" -v d="$dim" 'BEGIN { printf "%d\n", int((p * d / 100) + 0.5) }'
}

basename_no_ext() {
  local path="$1"
  local name
  name="$(basename "$path")"
  printf '%s\n' "${name%.*}"
}

escape_label_percent() {
  local raw="$1"
  printf '%s\n' "${raw%%%}"
}

require_cmd ffmpeg
require_cmd ffprobe
require_cmd awk

if (( $# == 0 )); then
  usage
  exit 1
fi

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

input_file="$1"
shift

[[ -f "$input_file" ]] || die "Input file not found: $input_file"

top_raw="5%"
bottom_raw="15%"
left_raw="15%"
right_raw="5%"
low_thr="40"
high_thr="80"
frame_seconds=""
intro_preserve_seconds=""
intro_blackout_seconds=""
outro_preserve_seconds=""
outro_blackout_seconds=""
zoom_pct=""
corners_only="false"
invert_bands="false"
outline_n="2"
output_dir=""
sung_color_default="00C800"
sung_color="$sung_color_default"
bg_color=""
bg_strength="85"
bg_range="35"
bg_blend="10"
no_lut="false"

while (( $# > 0 )); do
  case "$1" in
    -t)
      (( $# >= 2 )) || die "Missing value for -t"
      top_raw="$2"
      shift 2
      ;;
    -b)
      (( $# >= 2 )) || die "Missing value for -b"
      bottom_raw="$2"
      shift 2
      ;;
    -l)
      (( $# >= 2 )) || die "Missing value for -l"
      left_raw="$2"
      shift 2
      ;;
    -r)
      (( $# >= 2 )) || die "Missing value for -r"
      right_raw="$2"
      shift 2
      ;;
    -lo)
      (( $# >= 2 )) || die "Missing value for -lo"
      low_thr="$2"
      shift 2
      ;;
    -hi)
      (( $# >= 2 )) || die "Missing value for -hi"
      high_thr="$2"
      shift 2
      ;;
    -f)
      (( $# >= 2 )) || die "Missing value for -f"
      frame_seconds="$2"
      shift 2
      ;;
    --intro-preserve)
      (( $# >= 2 )) || die "Missing value for --intro-preserve"
      intro_preserve_seconds="$2"
      shift 2
      ;;
    --intro-blackout)
      (( $# >= 2 )) || die "Missing value for --intro-blackout"
      intro_blackout_seconds="$2"
      shift 2
      ;;
    --outro-preserve)
      (( $# >= 2 )) || die "Missing value for --outro-preserve"
      outro_preserve_seconds="$2"
      shift 2
      ;;
    --outro-blackout)
      (( $# >= 2 )) || die "Missing value for --outro-blackout"
      outro_blackout_seconds="$2"
      shift 2
      ;;
    -z)
      (( $# >= 2 )) || die "Missing value for -z"
      zoom_pct="$2"
      shift 2
      ;;
    --corners-only)
      corners_only="true"
      shift
      ;;
    --invert-bands)
      invert_bands="true"
      shift
      ;;
    --outline)
      (( $# >= 2 )) || die "Missing value for --outline"
      outline_n="$2"
      shift 2
      ;;
    -o)
      (( $# >= 2 )) || die "Missing value for -o"
      output_dir="$2"
      shift 2
      ;;
    --sung-color)
      (( $# >= 2 )) || die "Missing value for --sung-color"
      sung_color="$2"
      shift 2
      ;;
    --bg-color)
      (( $# >= 2 )) || die "Missing value for --bg-color"
      bg_color="$2"
      shift 2
      ;;
    --bg-strength)
      (( $# >= 2 )) || die "Missing value for --bg-strength"
      bg_strength="$2"
      shift 2
      ;;
    --bg-range)
      (( $# >= 2 )) || die "Missing value for --bg-range"
      bg_range="$2"
      shift 2
      ;;
    --bg-blend)
      (( $# >= 2 )) || die "Missing value for --bg-blend"
      bg_blend="$2"
      shift 2
      ;;
    --no-lut)
      no_lut="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

top_mask_pct="$(parse_percent "$top_raw")"
bottom_mask_pct="$(parse_percent "$bottom_raw")"
left_mask_pct="$(parse_percent "$left_raw")"
right_mask_pct="$(parse_percent "$right_raw")"

validate_threshold "Lower threshold" "$low_thr"
validate_threshold "Upper threshold" "$high_thr"
(( low_thr < high_thr )) || die "Lower threshold must be less than upper threshold"

if [[ -n "$frame_seconds" ]]; then
  [[ "$frame_seconds" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "-f must be a non-negative number of seconds"
fi

validate_seconds_flag() {
  local flag="$1" value="$2"
  [[ -z "$value" ]] && return 0
  [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "$flag must be a non-negative number of seconds"
  awk -v s="$value" 'BEGIN { exit !(s > 0) }' \
    || die "$flag must be greater than 0 (omit $flag to leave that segment unchanged)"
}

validate_seconds_flag --intro-preserve "$intro_preserve_seconds"
validate_seconds_flag --intro-blackout "$intro_blackout_seconds"
validate_seconds_flag --outro-preserve "$outro_preserve_seconds"
validate_seconds_flag --outro-blackout "$outro_blackout_seconds"

if [[ -n "$intro_preserve_seconds" && -n "$intro_blackout_seconds" ]]; then
  die "--intro-preserve and --intro-blackout are mutually exclusive"
fi
if [[ -n "$outro_preserve_seconds" && -n "$outro_blackout_seconds" ]]; then
  die "--outro-preserve and --outro-blackout are mutually exclusive"
fi

if [[ -n "$frame_seconds" ]]; then
  for pair in "--intro-preserve:intro_preserve_seconds" \
              "--intro-blackout:intro_blackout_seconds" \
              "--outro-preserve:outro_preserve_seconds" \
              "--outro-blackout:outro_blackout_seconds"; do
    flag="${pair%%:*}"
    var="${pair#*:}"
    if [[ -n "${!var}" ]]; then
      echo "Note: $flag ignored in still-frame mode (-f)." >&2
      printf -v "$var" '%s' ""
    fi
  done
fi

if [[ -n "$zoom_pct" ]]; then
  [[ "$zoom_pct" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "-z must be a non-negative number (percent)"
  awk -v z="$zoom_pct" 'BEGIN { exit !(z > 0 && z <= 100) }' \
    || die "-z must be greater than 0 and at most 100 (percent)"
fi

[[ "$outline_n" =~ ^[0-9]+$ ]] || die "--outline must be a non-negative integer"
(( outline_n >= 0 && outline_n <= 20 )) || die "--outline must be between 0 and 20"

bg_darken_active="false"
if [[ -n "$bg_color" ]]; then
  bg_color="${bg_color#\#}"
  bg_color="$(printf '%s' "$bg_color" | tr '[:lower:]' '[:upper:]')"
  [[ "$bg_color" =~ ^[0-9A-F]{6}$ ]] || die "--bg-color must be 6 hex digits, got: $bg_color"
  for pair in "--bg-strength:$bg_strength" "--bg-range:$bg_range" "--bg-blend:$bg_blend"; do
    name="${pair%%:*}"
    val="${pair#*:}"
    [[ "$val" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "$name must be a number 0-100, got: $val"
    awk -v x="$val" 'BEGIN { exit !(x >= 0 && x <= 100) }' || die "$name must be 0-100, got: $val"
  done
  bg_darken_active="true"
fi

width="$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 "$input_file")"
height="$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=p=0 "$input_file")"

[[ -n "$width" && -n "$height" ]] || die "Could not determine video dimensions"

# Resolve intro / outro into a single (mode, seconds) per side. Modes:
#   "preserve" — keep original frames in that segment
#   "blackout" — replace those frames with a fully black frame
#   "none"     — no concat for that side
intro_mode="none"
intro_seconds=""
if [[ -n "$intro_preserve_seconds" ]]; then
  intro_mode="preserve"; intro_seconds="$intro_preserve_seconds"
elif [[ -n "$intro_blackout_seconds" ]]; then
  intro_mode="blackout"; intro_seconds="$intro_blackout_seconds"
fi

outro_mode="none"
outro_seconds=""
if [[ -n "$outro_preserve_seconds" ]]; then
  outro_mode="preserve"; outro_seconds="$outro_preserve_seconds"
elif [[ -n "$outro_blackout_seconds" ]]; then
  outro_mode="blackout"; outro_seconds="$outro_blackout_seconds"
fi

duration=""
if [[ "$intro_mode" != "none" || "$outro_mode" != "none" ]]; then
  duration="$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$input_file")"
  [[ -n "$duration" ]] || die "Could not determine video duration"

  if [[ "$intro_mode" != "none" ]]; then
    awk -v s="$intro_seconds" -v d="$duration" 'BEGIN { exit !(s < d) }' \
      || die "intro duration ($intro_seconds) must be less than video duration ($duration)"
  fi
  if [[ "$outro_mode" != "none" ]]; then
    awk -v s="$outro_seconds" -v d="$duration" 'BEGIN { exit !(s < d) }' \
      || die "outro duration ($outro_seconds) must be less than video duration ($duration)"
  fi
  if [[ "$intro_mode" != "none" && "$outro_mode" != "none" ]]; then
    awk -v i="$intro_seconds" -v o="$outro_seconds" -v d="$duration" 'BEGIN { exit !(i + o < d) }' \
      || die "intro ($intro_seconds) + outro ($outro_seconds) must be less than video duration ($duration)"
  fi
fi

left_mask_px="$(percent_to_px "$left_mask_pct" "$width")"
right_mask_px="$(percent_to_px "$right_mask_pct" "$width")"
top_mask_px="$(percent_to_px "$top_mask_pct" "$height")"
bottom_mask_px="$(percent_to_px "$bottom_mask_pct" "$height")"

(( left_mask_px >= 0 && left_mask_px <= width )) || die "Computed left margin is out of range"
(( right_mask_px >= 0 && right_mask_px <= width )) || die "Computed right margin is out of range"
(( top_mask_px >= 0 && top_mask_px <= height )) || die "Computed top margin is out of range"
(( bottom_mask_px >= 0 && bottom_mask_px <= height )) || die "Computed bottom margin is out of range"
(( left_mask_px + right_mask_px < width )) || die "Left + right margins must leave visible width"
(( top_mask_px + bottom_mask_px < height )) || die "Top + bottom margins must leave visible height"

left_px="$left_mask_px"
right_px=$(( width - right_mask_px ))
top_px="$top_mask_px"
bottom_px=$(( height - bottom_mask_px ))

base_name="$(basename_no_ext "$input_file")"
input_dir="$(cd "$(dirname "$input_file")" && pwd)"
if [[ -n "$output_dir" ]]; then
  mkdir -p "$output_dir" || die "Could not create output directory: $output_dir"
  output_base="$(cd "$output_dir" && pwd)"
else
  output_base="$input_dir"
fi
top_label="$(escape_label_percent "$top_raw")"
bottom_label="$(escape_label_percent "$bottom_raw")"
left_label="$(escape_label_percent "$left_raw")"
right_label="$(escape_label_percent "$right_raw")"
box_label="box-${top_label}-${bottom_label}-${left_label}-${right_label}"
# Normalize sung color (strip leading #, uppercase, validate hex)
sung_color="${sung_color#\#}"
sung_color="$(printf '%s' "$sung_color" | tr '[:lower:]' '[:upper:]')"
[[ "$sung_color" =~ ^[0-9A-F]{6}$ ]] || die "--sung-color must be 6 hex digits, got: $sung_color"
sung_r=$((16#${sung_color:0:2}))
sung_g=$((16#${sung_color:2:2}))
sung_b=$((16#${sung_color:4:2}))

sung_label_segment=""
if [[ "$sung_color" != "$sung_color_default" ]]; then
  sung_label_segment="-sung${sung_color}"
fi

if [[ "$no_lut" == "true" ]]; then
  thr_label="nolut"
  mid_r="255";    mid_g="255";    mid_b="255"
  hi_r="$sung_r"; hi_g="$sung_g"; hi_b="$sung_b"
elif [[ "$invert_bands" == "true" ]]; then
  thr_label="bgw-${low_thr}-${high_thr}${sung_label_segment}"
  mid_r="$sung_r"; mid_g="$sung_g"; mid_b="$sung_b"
  hi_r="255";      hi_g="255";      hi_b="255"
else
  thr_label="bwg-${low_thr}-${high_thr}${sung_label_segment}"
  mid_r="255";    mid_g="255";    mid_b="255"
  hi_r="$sung_r"; hi_g="$sung_g"; hi_b="$sung_b"
fi

zoom_filter_segment=""
zoom_label_segment=""
if [[ -n "$zoom_pct" ]]; then
  zoom_factor="$(awk -v z="$zoom_pct" 'BEGIN { printf "%.6f", 1 + z/100 }')"
  zoom_filter_segment=",scale=iw*${zoom_factor}:ih*${zoom_factor},crop=${width}:${height}"
  zoom_pct_label="${zoom_pct//./_}"
  zoom_label_segment=" zoom-${zoom_pct_label}"
fi

intro_label_segment=""
case "$intro_mode" in
  preserve) intro_label_segment=" intro-keep-${intro_seconds//./_}" ;;
  blackout) intro_label_segment=" intro-bo-${intro_seconds//./_}" ;;
esac

outro_label_segment=""
case "$outro_mode" in
  preserve) outro_label_segment=" outro-keep-${outro_seconds//./_}" ;;
  blackout) outro_label_segment=" outro-bo-${outro_seconds//./_}" ;;
esac

bg_label_segment=""
bg_k=""
bg_sim=""
bg_blend_filter=""
if [[ "$bg_darken_active" == "true" ]]; then
  # DS percent -> luma multiplier K. DS=100 -> K=0 (black); DS=0 -> K=1 (no change).
  bg_k=$(awk -v ds="$bg_strength" 'BEGIN { printf "%.4f", (100-ds)/100 }')
  # CR percent -> colorkey similarity. The useful colorkey range on Karafun-style
  # backgrounds is roughly 0.02 (very narrow) to 0.20 (eats text edges); we map
  # CR 0-100 -> similarity 0.01-0.30 so the slider has meaningful action across
  # its full range. CR=35 -> 0.11 (a typical good value).
  bg_sim=$(awk -v cr="$bg_range" 'BEGIN { printf "%.4f", 0.01 + (cr/100)*0.29 }')
  bg_blend_filter=$(awk -v bl="$bg_blend" 'BEGIN { printf "%.4f", bl/100 }')
  bg_ds_int=$(awk -v x="$bg_strength" 'BEGIN { printf "%d", x+0.5 }')
  bg_cr_int=$(awk -v x="$bg_range" 'BEGIN { printf "%d", x+0.5 }')
  bg_bl_int=$(awk -v x="$bg_blend" 'BEGIN { printf "%d", x+0.5 }')
  bg_label_segment=" bg-${bg_color}-DS${bg_ds_int}-CR${bg_cr_int}-BL${bg_bl_int}"
fi

# Build mask_filter from non-empty strips only. ffmpeg's drawbox treats w=0 or
# h=0 as "use the full input dimension", so emitting a strip with a zero side
# would paint the whole frame black — skip those entirely. With no margins set,
# fall back to a passthrough `null` filter.
mask_parts=()
if [[ "$corners_only" == "true" ]]; then
  if (( top_px > 0 && left_px > 0 )); then
    mask_parts+=("drawbox=x=0:y=0:w=${left_px}:h=${top_px}:color=black:t=fill")
  fi
  if (( top_px > 0 && right_mask_px > 0 )); then
    mask_parts+=("drawbox=x=${right_px}:y=0:w=iw-${right_px}:h=${top_px}:color=black:t=fill")
  fi
  if (( bottom_mask_px > 0 && left_px > 0 )); then
    mask_parts+=("drawbox=x=0:y=${bottom_px}:w=${left_px}:h=ih-${bottom_px}:color=black:t=fill")
  fi
  if (( bottom_mask_px > 0 && right_mask_px > 0 )); then
    mask_parts+=("drawbox=x=${right_px}:y=${bottom_px}:w=iw-${right_px}:h=ih-${bottom_px}:color=black:t=fill")
  fi
  box_mode_label="corners"
else
  if (( top_px > 0 )); then
    mask_parts+=("drawbox=x=0:y=0:w=iw:h=${top_px}:color=black:t=fill")
  fi
  if (( bottom_mask_px > 0 )); then
    mask_parts+=("drawbox=x=0:y=${bottom_px}:w=iw:h=ih-${bottom_px}:color=black:t=fill")
  fi
  if (( left_px > 0 )); then
    mask_parts+=("drawbox=x=0:y=${top_px}:w=${left_px}:h=${bottom_px}-${top_px}:color=black:t=fill")
  fi
  if (( right_mask_px > 0 )); then
    mask_parts+=("drawbox=x=${right_px}:y=${top_px}:w=iw-${right_px}:h=${bottom_px}-${top_px}:color=black:t=fill")
  fi
  box_mode_label="outer"
fi
if (( ${#mask_parts[@]} > 0 )); then
  mask_filter="$(IFS=,; echo "${mask_parts[*]}")"
else
  mask_filter="null"
fi
masked_filter_zoomed="${mask_filter}${zoom_filter_segment}"
lut_r="if(lt(val,${low_thr}),0,if(lt(val,${high_thr}),${mid_r},${hi_r}))"
lut_g="if(lt(val,${low_thr}),0,if(lt(val,${high_thr}),${mid_g},${hi_g}))"
lut_b="if(lt(val,${low_thr}),0,if(lt(val,${high_thr}),${mid_b},${hi_b}))"
if [[ "$no_lut" == "true" ]]; then
  process_filter="${masked_filter_zoomed}"
else
  process_filter="${masked_filter_zoomed},hue=s=0,lutrgb=r='${lut_r}':g='${lut_g}':b='${lut_b}'"
fi

outline_chain=""
outline_label_segment=""
if (( outline_n > 0 )); then
  outer_off=$(( 2 * outline_n ))
  inner_off="$outline_n"
  outline_label_segment=" outline-${outline_n}"

  outline_chain="[lut]split=3[ol_bg_src][ol_orig_src][ol_gray_src];"
  outline_chain+="[ol_bg_src]lutrgb=r=0:g=0:b=0[ol_bg];"
  outline_chain+="[ol_orig_src]format=rgba,colorkey=color=0x000000:similarity=0.01:blend=0[ol_orig_keyed];"
  outline_chain+="[ol_gray_src]split=2[ol_outer_src][ol_inner_src];"
  outline_chain+="[ol_outer_src]hue=s=0,lutrgb=r='if(gt(val,1),220,0)':g='if(gt(val,1),220,0)':b='if(gt(val,1),220,0)',format=rgba,colorkey=color=0x000000:similarity=0.01:blend=0,split=8[oN][oNE][oE][oSE][oS][oSW][oW][oNW];"
  outline_chain+="[ol_inner_src]hue=s=0,lutrgb=r='if(gt(val,1),80,0)':g='if(gt(val,1),80,0)':b='if(gt(val,1),80,0)',format=rgba,colorkey=color=0x000000:similarity=0.01:blend=0,split=8[iN][iNE][iE][iSE][iS][iSW][iW][iNW];"
  outline_chain+="[ol_bg][oN]overlay=x=0:y=-${outer_off}[ols1];"
  outline_chain+="[ols1][oNE]overlay=x=${outer_off}:y=-${outer_off}[ols2];"
  outline_chain+="[ols2][oE]overlay=x=${outer_off}:y=0[ols3];"
  outline_chain+="[ols3][oSE]overlay=x=${outer_off}:y=${outer_off}[ols4];"
  outline_chain+="[ols4][oS]overlay=x=0:y=${outer_off}[ols5];"
  outline_chain+="[ols5][oSW]overlay=x=-${outer_off}:y=${outer_off}[ols6];"
  outline_chain+="[ols6][oW]overlay=x=-${outer_off}:y=0[ols7];"
  outline_chain+="[ols7][oNW]overlay=x=-${outer_off}:y=-${outer_off}[ols8];"
  outline_chain+="[ols8][iN]overlay=x=0:y=-${inner_off}[ols9];"
  outline_chain+="[ols9][iNE]overlay=x=${inner_off}:y=-${inner_off}[ols10];"
  outline_chain+="[ols10][iE]overlay=x=${inner_off}:y=0[ols11];"
  outline_chain+="[ols11][iSE]overlay=x=${inner_off}:y=${inner_off}[ols12];"
  outline_chain+="[ols12][iS]overlay=x=0:y=${inner_off}[ols13];"
  outline_chain+="[ols13][iSW]overlay=x=-${inner_off}:y=${inner_off}[ols14];"
  outline_chain+="[ols14][iW]overlay=x=-${inner_off}:y=0[ols15];"
  outline_chain+="[ols15][iNW]overlay=x=-${inner_off}:y=-${inner_off}[ols16];"
  outline_chain+="[ols16][ol_orig_keyed]overlay=x=0:y=0[outlined]"
fi

# Build a labeled filter_complex chain that takes a prefix (e.g. "[0:v]" or
# "[0:v]trim=...,setpts=...,") and produces "[lut]". Used when bg-darken is
# active (split/overlay require labeled pads). When bg-darken is off, callers
# can use the simpler $process_filter as a comma-chain.
build_lut_complex() {
  local prefix="$1"
  local out=""
  out+="${prefix}${mask_filter},split=2[bg_a][bg_b];"
  # Darken matched pixels toward true black: scale luma by K and pull chroma
  # toward neutral 128 by the same factor. In LUT mode the chroma move is a
  # no-op (the downstream hue=s=0,lutrgb pass overwrites chroma anyway); in
  # --no-lut mode it's what stops blue from bleeding through after dimming.
  out+="[bg_b]lutyuv=y='val*${bg_k}':u='128+(val-128)*${bg_k}':v='128+(val-128)*${bg_k}'[bg_dim];"
  out+="[bg_a]colorkey=color=0x${bg_color}:similarity=${bg_sim}:blend=${bg_blend_filter}[bg_keyed];"
  if [[ "$no_lut" == "true" ]]; then
    out+="[bg_dim][bg_keyed]overlay,format=yuv420p${zoom_filter_segment}[lut]"
  else
    out+="[bg_dim][bg_keyed]overlay,format=yuv420p${zoom_filter_segment},hue=s=0,lutrgb=r='${lut_r}':g='${lut_g}':b='${lut_b}'[lut]"
  fi
  printf '%s' "$out"
}

if [[ -n "$frame_seconds" ]]; then
  frame_label="${frame_seconds//./_}"
  masked_png="${output_base}/${base_name} [frame-${frame_label} masked-${box_mode_label} ${box_label}${zoom_label_segment}].png"
  processed_png="${output_base}/${base_name} [frame-${frame_label} processed-${box_mode_label} ${box_label}${zoom_label_segment}${outline_label_segment} ${thr_label}${bg_label_segment}].png"

  ffmpeg -y -ss "$frame_seconds" -i "$input_file" \
    -frames:v 1 -vf "$masked_filter_zoomed" -update 1 "$masked_png"

  if [[ "$bg_darken_active" == "true" ]]; then
    fc="$(build_lut_complex '[0:v]')"
    if [[ -n "$outline_chain" ]]; then
      ffmpeg -y -ss "$frame_seconds" -i "$input_file" \
        -filter_complex "${fc};${outline_chain}" \
        -map "[outlined]" -frames:v 1 -update 1 "$processed_png"
    else
      ffmpeg -y -ss "$frame_seconds" -i "$input_file" \
        -filter_complex "$fc" \
        -map "[lut]" -frames:v 1 -update 1 "$processed_png"
    fi
  elif [[ -n "$outline_chain" ]]; then
    ffmpeg -y -ss "$frame_seconds" -i "$input_file" \
      -filter_complex "[0:v]${process_filter}[lut];${outline_chain}" \
      -map "[outlined]" -frames:v 1 -update 1 "$processed_png"
  else
    ffmpeg -y -ss "$frame_seconds" -i "$input_file" \
      -frames:v 1 -vf "$process_filter" -update 1 "$processed_png"
  fi

  printf 'Created:\n%s\n%s\n' "$masked_png" "$processed_png"
elif [[ "$intro_mode" != "none" || "$outro_mode" != "none" ]]; then
  # Build the intro/outro branches and the body trim. Each side may be off,
  # in preserve mode (no extra filter), or in blackout mode (drawbox over the
  # full frame). The body branch trim covers the gap between the two sides
  # and keeps the original timeline so the original audio (mapped directly
  # from 0:a:0) stays in sync after concat.
  intro_branch=""
  if [[ "$intro_mode" != "none" ]]; then
    intro_extra_filter=""
    [[ "$intro_mode" == "blackout" ]] && intro_extra_filter=",drawbox=x=0:y=0:w=iw:h=ih:color=black:t=fill"
    intro_branch="[0:v]trim=start=0:end=${intro_seconds},setpts=PTS-STARTPTS${intro_extra_filter},setsar=1[intro]"
  fi

  outro_branch=""
  outro_start=""
  if [[ "$outro_mode" != "none" ]]; then
    outro_start=$(awk -v d="$duration" -v o="$outro_seconds" 'BEGIN { printf "%.6f", d - o }')
    outro_extra_filter=""
    [[ "$outro_mode" == "blackout" ]] && outro_extra_filter=",drawbox=x=0:y=0:w=iw:h=ih:color=black:t=fill"
    outro_branch="[0:v]trim=start=${outro_start}:end=${duration},setpts=PTS-STARTPTS${outro_extra_filter},setsar=1[outro]"
  fi

  if [[ "$intro_mode" != "none" && "$outro_mode" != "none" ]]; then
    body_trim="trim=start=${intro_seconds}:end=${outro_start},setpts=PTS-STARTPTS,"
  elif [[ "$intro_mode" != "none" ]]; then
    body_trim="trim=start=${intro_seconds},setpts=PTS-STARTPTS,"
  else
    body_trim="trim=start=0:end=${outro_start},setpts=PTS-STARTPTS,"
  fi
  body_prefix="[0:v]${body_trim}"

  concat_inputs=""
  concat_n=0
  if [[ "$intro_mode" != "none" ]]; then
    concat_inputs+="[intro]"
    concat_n=$((concat_n + 1))
  fi
  concat_inputs+="[body]"
  concat_n=$((concat_n + 1))
  if [[ "$outro_mode" != "none" ]]; then
    concat_inputs+="[outro]"
    concat_n=$((concat_n + 1))
  fi
  concat_filter="${concat_inputs}concat=n=${concat_n}:v=1:a=0[vout]"

  output_video="${output_base}/${base_name} [${box_mode_label} ${box_label} ${thr_label}${bg_label_segment}${zoom_label_segment}${outline_label_segment}${intro_label_segment}${outro_label_segment}].mp4"

  fc=""
  [[ -n "$intro_branch" ]] && fc+="${intro_branch};"
  [[ -n "$outro_branch" ]] && fc+="${outro_branch};"

  if [[ "$bg_darken_active" == "true" ]]; then
    fc+="$(build_lut_complex "$body_prefix")"
    if [[ -n "$outline_chain" ]]; then
      fc+=";${outline_chain};[outlined]setsar=1[body];"
    else
      fc+=";[lut]setsar=1[body];"
    fi
  elif [[ -n "$outline_chain" ]]; then
    fc+="${body_prefix}${process_filter}[lut];"
    fc+="${outline_chain};"
    fc+="[outlined]setsar=1[body];"
  else
    fc+="${body_prefix}${process_filter},setsar=1[body];"
  fi

  fc+="${concat_filter}"
  filter_complex="$fc"

  ffmpeg -y -i "$input_file" \
    -filter_complex "$filter_complex" \
    -map "[vout]" -map 0:a:0 -map_chapters -1 -dn \
    -c:v libx264 -pix_fmt yuv420p -crf 18 -preset medium -c:a copy \
    "$output_video"

  printf 'Created:\n%s\n' "$output_video"
else
  output_video="${output_base}/${base_name} [${box_mode_label} ${box_label} ${thr_label}${bg_label_segment}${zoom_label_segment}${outline_label_segment}].mp4"

  if [[ "$bg_darken_active" == "true" ]]; then
    fc="$(build_lut_complex '[0:v]')"
    if [[ -n "$outline_chain" ]]; then
      ffmpeg -y -i "$input_file" \
        -filter_complex "${fc};${outline_chain}" \
        -map "[outlined]" -map 0:a:0 -map_chapters -1 -dn \
        -c:v libx264 -pix_fmt yuv420p -crf 18 -preset medium -c:a copy \
        "$output_video"
    else
      ffmpeg -y -i "$input_file" \
        -filter_complex "$fc" \
        -map "[lut]" -map 0:a:0 -map_chapters -1 -dn \
        -c:v libx264 -pix_fmt yuv420p -crf 18 -preset medium -c:a copy \
        "$output_video"
    fi
  elif [[ -n "$outline_chain" ]]; then
    ffmpeg -y -i "$input_file" \
      -filter_complex "[0:v]${process_filter}[lut];${outline_chain}" \
      -map "[outlined]" -map 0:a:0 -map_chapters -1 -dn \
      -c:v libx264 -pix_fmt yuv420p -crf 18 -preset medium -c:a copy \
      "$output_video"
  else
    ffmpeg -y -i "$input_file" \
      -map 0:v:0 -map 0:a:0 -map_chapters -1 -dn \
      -vf "$process_filter" \
      -c:v libx264 -pix_fmt yuv420p -crf 18 -preset medium -c:a copy \
      "$output_video"
  fi

  printf 'Created:\n%s\n' "$output_video"
fi
